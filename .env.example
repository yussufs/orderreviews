# Database (matches compose.yaml for local development)
# Shared by Drizzle, the SvelteKit app, and the pg-boss worker.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/shopify_app"

# --- Shopify (populated by `shopify app env pull`) ---
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# SCOPES=write_products,read_orders

# --- App URL (absolute) — used for feedback-email token links & billing return ---
# In dev the order webhook captures the live tunnel URL (SHOPIFY_APP_URL/HOST injected
# by `shopify app dev`), so nothing extra is needed. In production, set SHOPIFY_APP_URL
# to your stable public URL — it MUST include the scheme, e.g. https://your-app.example.com
# SHOPIFY_APP_URL="https://your-app.example.com"

# --- Google Places API (New) — business search + place details ---
GOOGLE_PLACES_API_KEY=

# --- Apify — Google reviews import ---
APIFY_API_TOKEN=
APIFY_GOOGLE_REVIEWS_ACTOR_ID=compass/crawler-google-places
APIFY_GOOGLE_PLACE_SEARCH_ACTOR_ID=

# --- AWS SES — transactional email (review request, follow-up, merchant notify) ---
AWS_SES_REGION=us-east-1
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
AWS_SES_FROM_EMAIL=
# Where the in-app Support form delivers messages. Defaults to help@dragonapps.io.
AWS_SES_TO_EMAIL=

# Secret used to sign feedback landing-page tokens. Defaults to SHOPIFY_API_SECRET if unset.
FEEDBACK_TOKEN_SECRET=

# Dev: when "true", emails are logged to the console instead of being sent via SES.
EMAIL_DRYRUN=false
