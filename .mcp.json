{
	"mcpServers": {
		"svelte": {
			"type": "stdio",
			"command": "npx",
			"args": ["-y", "@sveltejs/mcp"],
			"env": {}
		},
		"shopify-dev-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": ["-y", "@shopify/dev-mcp@latest"],
			"env": {}
		},
		"context7": {
			"type": "stdio",
			"command": "npx",
			"args": ["-y", "@upstash/context7-mcp@latest"],
			"env": {}
		}
	}
}
