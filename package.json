{
	"name": "sveltekit-shopify-app",
	"description": "SvelteKit template for building Shopify embedded apps",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"license": "MIT",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"start": "node build",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check .",
		"graphql-codegen": "graphql-codegen",
		"graphql-codegen:watch": "graphql-codegen --watch",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"shopify": "shopify",
		"config:link": "shopify app config link",
		"deploy": "shopify app deploy"
	},
	"devDependencies": {
		"@graphql-codegen/cli": "^6.1.0",
		"@shopify/api-codegen-preset": "^1.2.1",
		"@sveltejs/adapter-node": "^5.2.0",
		"@sveltejs/kit": "^2.49.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@types/node": "^25.0.3",
		"drizzle-kit": "^0.31.8",
		"graphql-config": "^5.1.5",
		"prettier": "^3.7.4",
		"prettier-plugin-svelte": "^3.4.0",
		"svelte": "^5.45.6",
		"svelte-check": "^4.3.4",
		"typescript": "^5.9.3",
		"vite": "^7.2.6"
	},
	"dependencies": {
		"@shopify/admin-api-client": "^1.1.1",
		"@shopify/shopify-api": "^12.2.0",
		"drizzle-orm": "^0.45.1",
		"graphql": "^16.12.0",
		"postgres": "^3.4.7"
	}
}
