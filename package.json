{
	"name": "sveltekit-shopify-app",
	"description": "SvelteKit template for building Shopify embedded apps",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"license": "MIT",
	"packageManager": "pnpm@10.27.0",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"start": "node build",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"graphql-codegen": "graphql-codegen",
		"graphql-codegen:watch": "graphql-codegen --watch",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"shopify": "shopify",
		"config:link": "shopify app config link",
		"deploy": "shopify app deploy",
		"worker": "tsx src/worker.ts",
		"worker:dev": "tsx watch src/worker.ts",
		"widget:install": "pnpm --dir widget install --ignore-workspace",
		"widget:build": "pnpm --dir widget build",
		"widget:dev": "pnpm --dir widget dev"
	},
	"devDependencies": {
		"@graphql-codegen/cli": "^6.1.0",
		"@shopify/api-codegen-preset": "^1.2.1",
		"@shopify/app-bridge-types": "^0.5.3",
		"@sveltejs/adapter-node": "^5.2.0",
		"@sveltejs/kit": "^2.49.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@types/node": "^25.0.3",
		"@types/qrcode": "^1.5.6",
		"drizzle-kit": "^0.31.8",
		"graphql-config": "^5.1.5",
		"prettier": "^3.7.4",
		"prettier-plugin-svelte": "^3.4.0",
		"svelte": "^5.45.6",
		"svelte-check": "^4.3.4",
		"typescript": "^5.9.3",
		"vite": "^7.2.6",
		"vite-node": "^5.3.0",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@aws-sdk/client-ses": "^3.1072.0",
		"tsx": "^4.22.4",
		"@shopify/admin-api-client": "^1.1.1",
		"@shopify/shopify-api": "^12.2.0",
		"apify-client": "^2.23.4",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.1",
		"graphql": "^16.12.0",
		"pg-boss": "^12.19.1",
		"postgres": "^3.4.7",
		"qrcode": "^1.5.4"
	}
}
